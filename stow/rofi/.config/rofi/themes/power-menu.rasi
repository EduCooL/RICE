@import "shared.rasi"

configuration {
    show-icons: false;
}

window {
    width: 300px;
    location: center;
    anchor: center;
}

mainbox {
    padding: 10px;
    spacing: 7px;
}

inputbar {
    children: [ prompt ];
    background-color: transparent;
    border: 0;
    padding: 2px 4px 4px 4px;
}

prompt {
    content: "power";
    text-color: @text-dim;
}

listview {
    lines: 5;
    fixed-height: true;
}

element {
    padding: 8px 9px;
}

element-icon {
    enabled: false;
    size: 0px;
    padding: 0px;
}

element-text {
    horizontal-align: 0.5;
}

element selected.normal {
    background-color: @sage-row;
    border-color: @border;
}
