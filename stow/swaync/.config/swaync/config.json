{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 640,
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 10,
  "control-center-margin-left": 0,
  "control-center-exclusive-zone": false,

  "notification-window-width": 360,
  "notification-icon-size": 44,
  "notification-body-image-height": 130,
  "notification-body-image-width": 180,
  "notification-grouping": true,
  "notification-2fa-action": true,
  "notification-inline-replies": false,

  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 160,
  "hide-on-clear": false,
  "hide-on-action": true,
  "relative-timestamps": true,
  "text-empty": "quiet inbox",

  "widgets": [
    "title",
    "dnd",
    "notifications",
    "mpris",
    "volume",
    "backlight",
    "buttons-grid"
  ],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "autohide": true,
      "loop-carousel": false
    },
    "volume": {
      "label": "Volume",
      "show-per-app": false,
      "show-per-app-icon": true,
      "expand-per-app": false
    },
    "backlight": {
      "label": "Brightness",
      "subsystem": "backlight",
      "min": 1
    },
    "buttons-grid": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "Lock",
          "command": "hyprlock"
        },
        {
          "label": "Reload",
          "command": "sh -c '$HOME/.config/hypr/scripts/reload.sh'"
        },
        {
          "label": "Power",
          "command": "sh -c '$HOME/.config/hypr/scripts/power-menu.sh'"
        }
      ]
    }
  }
}
